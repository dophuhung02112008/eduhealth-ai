{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/cron-articles", "dest": "/api/cron-articles.js" },
    { "src": "/api/scan", "dest": "/api/scan.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/articles", "dest": "/api/articles.js" },
    { "src": "/api/articles/(?<path>.*)", "dest": "/api/articles.js" },
    { "src": "/api/activity/(?<path>.*)", "dest": "/api/activity.js" },
    { "src": "/api/activity", "dest": "/api/activity.js" },
    { "src": "/health", "dest": "/api/health.js" },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-articles",
      "schedule": "0 7 * * *"
    }
  ]
}
